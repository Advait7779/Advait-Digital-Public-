datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Lead {
  id         Int      @id @default(autoincrement())
  name       String
  phone      String
  email      String?
  service    String?
  message    String?
  sourceForm String   @default("Website Form") @map("source_form")
  status     String   @default("New")
  ipAddress  String?  @map("ip_address")
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([status], map: "idx_leads_status")
  @@index([createdAt(sort: Desc)], map: "idx_leads_created_at")
  @@index([phone], map: "idx_leads_phone")
  @@map("leads")
}

model EmailTemplate {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  subject   String
  bodyHtml  String   @map("body_html")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("email_templates")
}

model AnalyticsVisit {
  id          Int      @id @default(autoincrement())
  ts          DateTime @default(now())
  page        String
  referrer    String?
  utmSource   String?  @map("utm_source")
  utmMedium   String?  @map("utm_medium")
  utmCampaign String?  @map("utm_campaign")
  device      String   @default("unknown")
  browser     String   @default("unknown")
  ipAddress   String?  @map("ip_address")
  sessionId   String?  @map("session_id")

  @@index([ts(sort: Desc)], map: "idx_analytics_visits_ts")
  @@index([page], map: "idx_analytics_visits_page")
  @@index([sessionId], map: "idx_analytics_visits_session")
  @@map("analytics_visits")
}

model AnalyticsCounter {
  key       String   @id
  value     Int      @default(0)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("analytics_counters")
}
