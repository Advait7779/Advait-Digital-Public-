# ===================================================
# ADVAIT DIGITAL - BACKEND CONFIGURATION
# ===================================================

# Server Port
PORT=5000
CORS_ORIGINS=https://advaitdigital.co.in,https://www.advaitdigital.co.in,http://localhost:5174,http://127.0.0.1:5174
TRUST_PROXY=1
API_RATE_LIMIT_PER_15_MIN=3000
LEAD_RATE_LIMIT_PER_15_MIN=20
ADMIN_RATE_LIMIT_PER_15_MIN=300
BACKGROUND_JOB_CONCURRENCY=5
BACKGROUND_JOB_MAX_QUEUE=5000
ANALYTICS_BASE_OFFSET=16000
ANALYTICS_RECENT_LIMIT=10000
REMINDER_EMAIL_ENABLED=true
REMINDER_EMAIL_DELAY_HOURS=48
REMINDER_EMAIL_CHECK_INTERVAL_MINUTES=15
REMINDER_EMAIL_BATCH_SIZE=25
REMINDER_EMAIL_MAX_ATTEMPTS=3
REMINDER_EMAIL_LOCK_MINUTES=30

# ---------------------------------------------------
# SMTP Email Credentials (Custom Mailer)
# ---------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=sales@advaitteleservices.com
SMTP_PASS=your_app_password_here
SMTP_FROM="Advait Digital" <sales@advaitteleservices.com>
NOTIFY_EMAIL=sales@advaitteleservices.com
SMTP_MAX_CONNECTIONS=3
SMTP_MAX_MESSAGES_PER_CONNECTION=100

# ---------------------------------------------------
# WhatsApp WABA API Credentials
# ---------------------------------------------------
WABA_API_KEY=your_waba_api_key_here
WABA_TARGET_NUMBER=919921968968
WABA_API_URL=https://api.advaitdigital.co.in/api/v1/messages

# ---------------------------------------------------
# PostgreSQL - CMS Database (Advait_digital_CMS)
# ---------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=Advait_digital_CMS
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here
# Optional. If omitted, backend scripts build this from DB_HOST/DB_PORT/DB_NAME/DB_USER/DB_PASSWORD.
DATABASE_URL=

# ---------------------------------------------------
# Admin CMS Panel
# Prefer ADMIN_PASSWORD_HASH in production:
# npm run admin:hash-password -- "your-long-admin-password"
# ---------------------------------------------------
ADMIN_EMAIL=admin@advaitdigital.co.in
ADMIN_PASSWORD_HASH=replace_with_generated_scrypt_hash
# Fallback only for local/dev compatibility. Avoid plaintext passwords in production.
ADMIN_SECRET=replace_with_local_dev_password_only
ADMIN_SESSION_SECRET=replace_with_a_long_random_session_secret
