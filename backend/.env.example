# Server Port
PORT=5000

# ---------------------------------------------------
# SMTP Email Credentials (Custom Mailer)
# ---------------------------------------------------
# Examples:
# Gmail: smtp.gmail.com (Port: 587)
# Hostinger/cPanel: smtp.hostinger.com or mail.advaitteleservices.com (Port: 465 or 587)
# ZoHo: smtp.zoho.com (Port: 465)

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=sales@advaitteleservices.com
SMTP_PASS=your_app_password_here
SMTP_FROM="Advait Digital Leads" <sales@advaitteleservices.com>
NOTIFY_EMAIL=sales@advaitteleservices.com

# ---------------------------------------------------
# WhatsApp WABA API Credentials
# ---------------------------------------------------
WABA_API_KEY=your_waba_api_key_here
WABA_TARGET_NUMBER=919921968968
